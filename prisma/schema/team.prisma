model Team {
  id                 String   @id @default(cuid())
  teamName           String
  stripe_customer_id String?
  plan               Plans
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // relation
  members TeamMembership[]
}

model TeamMembership {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   Roles

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  // I gave combined unique field so that no same user can join the same team again and again.
  // @@unique on userId and teamid means that it will combined and look them as unique.
  @@unique([userId, teamId])
}

model Invitation {
  id          String @id @default(cuid())
  inviteToken String
  inviteTo    String
  inviterId   String
  invitedBy   User   @relation(fields: [inviterId], references: [id])
}

enum Roles {
  OWNER
  MEMBER
}

enum Plans {
  FREE
  PRO
}
